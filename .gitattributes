# =========================
# Unity text serialization files
# Keep these in normal Git for diffs/merges
# =========================
*.cs             text diff=csharp
*.shader         text
*.compute        text
*.cginc          text
*.hlsl           text
*.json           text
*.xml            text
*.yaml           text
*.yml            text
*.txt            text
*.md             text
*.asmdef         text
*.asmref         text
*.rsp            text

*.unity          text
*.prefab         text
*.mat            text
*.anim           text
*.controller     text
*.meta           text
*.physicsMaterial2D text
*.physicsMaterial text

# Line endings
* text=auto

